# Required for all modes
AGENT_WALLET_SECRET=replace-with-a-strong-passphrase

# Network and signer mode
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
AGENT_SIGNER_MODE=kms

# GCP KMS (required when AGENT_SIGNER_MODE=kms)
AGENT_KMS_KEY_ID=projects/hedwig-487621/locations/global/keyRings/agentstack-ring/cryptoKeys/solana-agent-key/cryptoKeyVersions/1

# Choose ONE auth method for GCP runtime credentials
# 1) File path (Render secret file mount)
GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/gcp-sa.json

# 2) Inline JSON secret (Render env var)
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Runtime and WS security
AGENT_LOG_MAX=500
WS_AUTH_TOKEN=replace-with-websocket-token
WS_MAX_COMMANDS_PER_MIN=120
WS_HEARTBEAT_MS=20000
ALERT_BALANCE_DROP_SOL=0.5
AGENT_AIRDROP_COOLDOWN_MS=1800000

# Optional protocol integration (Pyth oracle reads)
AGENT_ENABLE_ORACLE_READS=true
AGENT_ORACLE_POLL_EVERY_TICKS=3
PYTH_HERMES_URL=https://hermes.pyth.network
PYTH_PRICE_FEED_ID=0xe62df6c8b4a85fe1a67db0f46fecfc02ca1a96db59ff16f33a6ef8e619f76f4a

# Dashboard client
VITE_WS_URL=ws://localhost:4000
VITE_WS_AUTH_TOKEN=replace-with-websocket-token
VITE_SIMULATED=false
